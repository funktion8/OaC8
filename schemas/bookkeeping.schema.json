{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BookkeepingProcess",
  "type": "object",
  "required": [
    "process_type",
    "request_id",
    "idempotency_key",
    "actor_context",
    "status",
    "year",
    "entry_date",
    "currency",
    "lines"
  ],
  "properties": {
    "process_type": {
      "const": "bookkeeping"
    },
    "request_id": {
      "type": "string",
      "pattern": "^REQ-[0-9]{4}-[0-9]{4}$"
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 8
    },
    "actor_context": {
      "type": "object",
      "required": [
        "actor_role",
        "requested_decision_type",
        "impact_level",
        "compliance_impact"
      ],
      "properties": {
        "actor_role": { "type": "string", "minLength": 2 },
        "actor_display": { "type": "string" },
        "requested_decision_type": {
          "type": "string",
          "enum": ["self_resolve", "requires_review", "requires_approval"]
        },
        "impact_level": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "compliance_impact": { "type": "boolean" },
        "requested_qualification": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "qualification_evidence": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "approver_role": { "type": "string" },
        "resolver_role": { "type": "string" }
      }
    },
    "status": {
      "type": "string",
      "enum": ["draft", "validated", "posted", "closed"]
    },
    "year": {
      "type": "integer",
      "minimum": 2020
    },
    "entry_date": {
      "type": "string",
      "format": "date"
    },
    "currency": {
      "type": "string",
      "minLength": 3,
      "maxLength": 3
    },
    "document_ref": {
      "type": "string"
    },
    "lines": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["account_code", "direction", "amount"],
        "properties": {
          "account_code": { "type": "string", "minLength": 1 },
          "direction": { "type": "string", "enum": ["debit", "credit"] },
          "amount": { "type": "number", "exclusiveMinimum": 0 },
          "tax_code": { "type": "string" },
          "cost_center": { "type": "string" }
        }
      }
    },
    "external_ref": {
      "type": "string"
    },
    "metadata": {
      "type": "object"
    }
  }
}
