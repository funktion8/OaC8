{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TaxProcess",
  "type": "object",
  "required": [
    "process_type",
    "request_id",
    "idempotency_key",
    "actor_context",
    "status",
    "year",
    "tax_type",
    "period"
  ],
  "properties": {
    "process_type": {
      "const": "tax"
    },
    "request_id": {
      "type": "string",
      "pattern": "^REQ-[0-9]{4}-[0-9]{4}$"
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 8
    },
    "actor_context": {
      "type": "object",
      "required": [
        "actor_role",
        "requested_decision_type",
        "impact_level",
        "compliance_impact"
      ],
      "properties": {
        "actor_role": { "type": "string", "minLength": 2 },
        "actor_display": { "type": "string" },
        "requested_decision_type": {
          "type": "string",
          "enum": ["self_resolve", "requires_review", "requires_approval"]
        },
        "impact_level": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "compliance_impact": { "type": "boolean" },
        "requested_qualification": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "qualification_evidence": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "approver_role": { "type": "string" },
        "resolver_role": { "type": "string" }
      }
    },
    "status": {
      "type": "string",
      "enum": ["draft", "prepared", "approved", "submitted", "archived"]
    },
    "year": {
      "type": "integer",
      "minimum": 2020
    },
    "tax_type": {
      "type": "string",
      "enum": ["ustva", "jahreserklaerung", "lohnsteuer", "gewerbesteuer"]
    },
    "period": {
      "type": "string",
      "pattern": "^[0-9]{4}(-[0-9]{2})?$"
    },
    "source_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "requires_review": {
      "type": "boolean"
    },
    "totals": {
      "type": "object",
      "properties": {
        "net_amount": { "type": "number" },
        "tax_amount": { "type": "number" },
        "gross_amount": { "type": "number" }
      }
    },
    "metadata": {
      "type": "object"
    }
  }
}
