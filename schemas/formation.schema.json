{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FormationProcess",
  "type": "object",
  "required": [
    "process_type",
    "request_id",
    "idempotency_key",
    "status",
    "year",
    "venture_name",
    "legal_form",
    "steps"
  ],
  "properties": {
    "process_type": {
      "const": "formation"
    },
    "request_id": {
      "type": "string",
      "pattern": "^REQ-[0-9]{4}-[0-9]{4}$"
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 8
    },
    "status": {
      "type": "string",
      "enum": ["draft", "validated", "needs_review", "approved", "executed", "archived"]
    },
    "year": {
      "type": "integer",
      "minimum": 2020
    },
    "venture_name": {
      "type": "string",
      "minLength": 1
    },
    "legal_form": {
      "type": "string",
      "minLength": 2
    },
    "seat": {
      "type": "string"
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "owner", "due_date"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "owner": { "type": "string", "minLength": 1 },
          "due_date": { "type": "string", "format": "date" },
          "status": { "type": "string" }
        }
      }
    },
    "metadata": {
      "type": "object"
    }
  }
}
