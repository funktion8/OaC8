{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FormationProcess",
  "type": "object",
  "required": [
    "process_type",
    "request_id",
    "idempotency_key",
    "actor_context",
    "status",
    "year",
    "venture_name",
    "legal_form",
    "steps"
  ],
  "properties": {
    "process_type": {
      "const": "formation"
    },
    "request_id": {
      "type": "string",
      "pattern": "^REQ-[0-9]{4}-[0-9]{4}$"
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 8
    },
    "actor_context": {
      "type": "object",
      "required": [
        "actor_role",
        "requested_decision_type",
        "impact_level",
        "compliance_impact"
      ],
      "properties": {
        "actor_role": { "type": "string", "minLength": 2 },
        "actor_display": { "type": "string" },
        "requested_decision_type": {
          "type": "string",
          "enum": ["self_resolve", "requires_review", "requires_approval"]
        },
        "impact_level": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "compliance_impact": { "type": "boolean" },
        "requested_qualification": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "qualification_evidence": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "approver_role": { "type": "string" },
        "resolver_role": { "type": "string" }
      }
    },
    "status": {
      "type": "string",
      "enum": ["draft", "validated", "needs_review", "approved", "executed", "archived"]
    },
    "year": {
      "type": "integer",
      "minimum": 2020
    },
    "venture_name": {
      "type": "string",
      "minLength": 1
    },
    "legal_form": {
      "type": "string",
      "minLength": 2
    },
    "seat": {
      "type": "string"
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "owner", "due_date"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "owner": { "type": "string", "minLength": 1 },
          "due_date": { "type": "string", "format": "date" },
          "status": { "type": "string" }
        }
      }
    },
    "metadata": {
      "type": "object"
    }
  }
}
