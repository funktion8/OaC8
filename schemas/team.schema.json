{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TeamProcess",
  "type": "object",
  "required": [
    "process_type",
    "request_id",
    "idempotency_key",
    "actor_context",
    "status",
    "year",
    "team"
  ],
  "properties": {
    "process_type": {
      "const": "team"
    },
    "request_id": {
      "type": "string",
      "pattern": "^REQ-[0-9]{4}-[0-9]{4}$"
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 8
    },
    "actor_context": {
      "type": "object",
      "required": [
        "actor_role",
        "requested_decision_type",
        "impact_level",
        "compliance_impact"
      ],
      "properties": {
        "actor_role": { "type": "string", "minLength": 2 },
        "actor_display": { "type": "string" },
        "requested_decision_type": {
          "type": "string",
          "enum": ["self_resolve", "requires_review", "requires_approval"]
        },
        "impact_level": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "compliance_impact": { "type": "boolean" },
        "approver_role": { "type": "string" },
        "resolver_role": { "type": "string" }
      }
    },
    "status": {
      "type": "string",
      "enum": ["draft", "validated", "needs_review", "approved", "executed", "archived"]
    },
    "year": {
      "type": "integer",
      "minimum": 2020
    },
    "team": {
      "type": "object",
      "required": [
        "id",
        "org_unit",
        "manager",
        "members_target",
        "access_profile",
        "tools"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 2
        },
        "org_unit": {
          "type": "string",
          "minLength": 2
        },
        "manager": {
          "type": "string",
          "minLength": 2
        },
        "members_target": {
          "type": "integer",
          "minimum": 1
        },
        "access_profile": {
          "type": "string",
          "minLength": 2
        },
        "tools": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 2
          }
        }
      }
    },
    "metadata": {
      "type": "object"
    }
  }
}
